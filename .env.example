# Mandatory variables you must set before starting Selfieproxy

PRIMARY_DOMAIN=example.com
# Bootstrap user the the bundled identity provider
ADMIN_PORTAL_USERNAME=admin
ADMIN_PORTAL_BOOTSTRAP_PASSWORD=change-me

# ===============================================================
# Optional parameters that can be left empty, with their defaults
# ===============================================================
# REVERSE_PROXY_LISTENER_SUBDOMAIN=proxylistener
# SELFPROXY_ADMIN_DOMAIN=selfieproxy
# DEFAULT_HOMELAB=my-homelab
# LOCAL_WEBSITE_DEMO_LABEL=www
# SELFPROXY_AUTH_DOMAIN=auth
# SELFPROXY_CONSOLE_DOMAIN=console
# LETSENCRYPT_EMAIL=

# SSO session lifetime (portal domain and any SSO-protected exposed app),
# in minutes.
# SSO_SESSION_IDLE_MINUTES=30
# SSO_SESSION_MAX_MINUTES=600

# Makes it harder for an internet provider or a restrictive Wi-Fi network to block a
# homelab agent from connecting to the Selfie Proxy server. Normally an agent connects
# over SSH, which some providers and locked-down Wi-Fi networks (hotels,
# campuses) block. With STEALTH_MODE enabled, the traffic between agent and server
# disguises itself as regular web browsing, using HTTPS on port 443 -- a port that's
# essentially never blocked.
# STEALTH_MODE=false

# ==========================================================
# Identity Provider for authentication
#
# Leave blank to use the bundled identity provider.
#
# Keycloak example:
#   OIDC_ISSUER_URL=https://keycloak.example.com/realms/myrealm
#   OIDC_CLIENT_ID=selfieproxy
#   OIDC_CLIENT_SECRET=changeme
#
# Authentik example:
#   OIDC_ISSUER_URL=https://authentik.example.com/application/o/selfieproxy/
#   OIDC_CLIENT_ID=selfieproxy
#   OIDC_CLIENT_SECRET=changeme
# ==========================================================
