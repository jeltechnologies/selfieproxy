DOMAIN=example.com
ADMIN_PORTAL_USERNAME=admin
ADMIN_PORTAL_PASSWORD=change-me

# Poweruser-only overrides, all optional with sensible defaults -- see the
# root CLAUDE.md for why these must agree across docker-compose-server.yaml/
# check-dns.sh/application.properties.
# REVERSE_PROXY_LISTENER=proxylistener
# SELFPROXY_ADMIN_DOMAIN=selfieproxy
# DEFAULT_HOMELAB=my-homelab
# SELFPROXY_SSO_DOMAIN=sso

# Set to true to make boringproxy log every request (timestamp, remote IP,
# method, host, path) to stdout -- noisy in normal operation (every agent
# poll and every Homelabs-page auto-refresh logs a line), so left off by
# default.
# BORINGPROXY_DEBUG=false

# BYO-OIDC override: point the admin portal (and any "Protect with SSO"
# exposed app) at an external IdP you already run instead of the bundled
# selfieproxy-sso-server. Leave blank to use the bundled server -- that's
# the default and needs no configuration beyond ADMIN_PORTAL_USERNAME/
# ADMIN_PORTAL_PASSWORD above.
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
