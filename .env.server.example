# Copy to .env on the server host (the machine with a public IP running
# docker-compose-server.yaml). .env is gitignored -- never commit it, it
# holds real credentials.

# Root domain you control DNS for. Must have DNS records (see below) pointing
# at this server's public IP before startup -- docker-compose-server.yaml's
# dns-check service refuses to start otherwise.
DOMAIN=example.com

# Subdomain boringproxy's own admin API/tunnel-control plane is reachable on.
# Requires an "A <BORING_PROXY_ADMIN_SUBDOMAIN> -> <this server's public IP>" record.
# Must match the agent host's own BORING_PROXY_ADMIN_SUBDOMAIN.
BORING_PROXY_ADMIN_SUBDOMAIN=admin

# Subdomain the Selfie Proxy admin portal (the web UI) is reachable on.
# Requires an "A <SELFIEPROXY_SUBDOMAIN> -> <this server's public IP>" record.
SELFIEPROXY_SUBDOMAIN=selfieproxy

# Email used for Let's Encrypt/ACME certificate registration.
ACME_EMAIL=you@example.com

# Login credentials for the Selfie Proxy admin portal itself.
ADMIN_PORTAL_USERNAME=admin
ADMIN_PORTAL_PASSWORD=change-me

# Name of the agent the portal auto-creates on first boot. After the server is
# up, log into the portal's Agents page, find this agent, and copy its
# generated secret into AGENT_SECRET in the agent host's .env.
AGENT_DEFAULT_NAME=homelab

# Name of the "This Server" homelab -- an ordinary Agent the portal
# auto-creates and runs colocated with the server itself (the
# this-server-agent service), for exposed apps hosted on this same VPS
# instead of a remote network. Unlike AGENT_DEFAULT_NAME, its secret never
# needs manual copy-paste -- see ThisServerBootstrap.
THIS_SERVER_AGENT_NAME=this-server
