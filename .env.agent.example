# Copy to .env on each agent host (a machine behind CGNAT, running
# docker-compose-agent.yaml). .env is gitignored -- never commit it, it
# holds real credentials.

# Root domain used by the server this agent connects to.
DOMAIN=example.com

# Subdomain of the server's boringproxy admin API/tunnel-control plane.
# Must match the server's own BORING_PROXY_ADMIN_SUBDOMAIN.
BORING_PROXY_ADMIN_SUBDOMAIN=admin

# Email used for Let's Encrypt/ACME certificate registration.
ACME_EMAIL=you@example.com

# Must match an agent name already registered on the server (either its
# AGENT_DEFAULT_NAME, or one created via the portal's Agents page).
AGENT_NAME=homelab

# Secret for AGENT_NAME, copied from the server's admin portal Agents page.
AGENT_SECRET=
